{
  "manifest_version": 3,
  "name": "RealBazzi Rain Monitor",
  "version": "2.2",
  "description": "Rain Monitor mit Auto Claim + GUI",
  "icons": {
   "16": "16x16.png",
   "32": "32x32.png",
   "48": "48x48.png",
   "128": "128x128.png"
 },
  "permissions": [],
  "host_permissions": [
    "https://realbazzi.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://realbazzi.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
